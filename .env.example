# Option 1: no-sudo localhost PostgreSQL created inside VS Code/Codespaces
DATABASE_URL=postgresql://vscode@localhost:5433/aptitude_db?sslmode=disable
PORT=8080
SESSION_SECURE=false

# Option 2: normal PostgreSQL installed on your laptop
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=aptitude_db
# DB_SSLMODE=disable
# PORT=8080
# SESSION_SECURE=false

# Option 3: Neon/Supabase/Render PostgreSQL
# DATABASE_URL=postgresql://username:password@your-host/your-database?sslmode=require
# PORT=8080
# SESSION_SECURE=false
